# Nexus-MCP Environment Variables
# Copy this file to .env and fill in your values

# ================================
# Server Configuration
# ================================
NEXUS_LOG_LEVEL=info
NEXUS_LOG_FORMAT=json
NEXUS_LOG_OUTPUT=stdout
NEXUS_LOG_FILE=logs/nexus.log

# ================================
# Filesystem Configuration
# ================================
NEXUS_FILESYSTEM_ENABLED=true
NEXUS_FILESYSTEM_ALLOWED_PATHS=/tmp,./workspace
NEXUS_FILESYSTEM_MAX_FILE_SIZE=100MB
NEXUS_FILESYSTEM_WATCH_ENABLED=false

# ================================
# HTTP Configuration
# ================================
NEXUS_HTTP_ENABLED=true
NEXUS_HTTP_TIMEOUT=30000
NEXUS_HTTP_MAX_REDIRECTS=5
NEXUS_HTTP_USER_AGENT=Nexus-MCP/1.0
NEXUS_HTTP_PROXY_HOST=
NEXUS_HTTP_PROXY_PORT=
NEXUS_HTTP_PROXY_USERNAME=
NEXUS_HTTP_PROXY_PASSWORD=

# ================================
# Git Configuration
# ================================
NEXUS_GIT_ENABLED=true
NEXUS_GIT_DEFAULT_BRANCH=main
NEXUS_GIT_SSH_KEY_PATH=~/.ssh/id_rsa
NEXUS_GIT_SSH_KEY_PASSPHRASE=
NEXUS_GIT_GITHUB_TOKEN=
NEXUS_GIT_GITLAB_TOKEN=
NEXUS_GIT_BITBUCKET_USERNAME=
NEXUS_GIT_BITBUCKET_APP_PASSWORD=

# ================================
# Database Configuration
# ================================
NEXUS_DATABASE_ENABLED=true
NEXUS_DATABASE_DEFAULT_CONNECTION=postgresql

# PostgreSQL
NEXUS_DB_POSTGRESQL_HOST=localhost
NEXUS_DB_POSTGRESQL_PORT=5432
NEXUS_DB_POSTGRESQL_DATABASE=nexus
NEXUS_DB_POSTGRESQL_USER=nexus
NEXUS_DB_POSTGRESQL_PASSWORD=
NEXUS_DB_POSTGRESQL_SSL=false

# MySQL/MariaDB
NEXUS_DB_MYSQL_HOST=localhost
NEXUS_DB_MYSQL_PORT=3306
NEXUS_DB_MYSQL_DATABASE=nexus
NEXUS_DB_MYSQL_USER=nexus
NEXUS_DB_MYSQL_PASSWORD=
NEXUS_DB_MYSQL_SSL=false

# SQLite
NEXUS_DB_SQLITE_PATH=./data/nexus.db

# SQL Server
NEXUS_DB_SQLSERVER_HOST=localhost
NEXUS_DB_SQLSERVER_PORT=1433
NEXUS_DB_SQLSERVER_DATABASE=nexus
NEXUS_DB_SQLSERVER_USER=nexus
NEXUS_DB_SQLSERVER_PASSWORD=
NEXUS_DB_SQLSERVER_ENCRYPT=true

# MongoDB
NEXUS_DB_MONGODB_URI=mongodb://localhost:27017/nexus
NEXUS_DB_MONGODB_USER=
NEXUS_DB_MONGODB_PASSWORD=

# ================================
# System Configuration
# ================================
NEXUS_SYSTEM_ENABLED=true
NEXUS_SYSTEM_ALLOW_SHELL_COMMANDS=true
NEXUS_SYSTEM_MAX_EXECUTION_TIME=60000
NEXUS_SYSTEM_ALLOWED_COMMANDS=ls,cd,cat,grep,find
NEXUS_SYSTEM_DENIED_COMMANDS=rm,dd,format

# ================================
# AI Configuration
# ================================
NEXUS_AI_ENABLED=true
NEXUS_AI_DEFAULT_PROVIDER=anthropic
NEXUS_AI_MAX_TOKENS=4096
NEXUS_AI_TEMPERATURE=0.7
NEXUS_AI_STREAM=false

# --- Anthropic Claude ---
# Used directly by the AI tools: ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=
NEXUS_AI_ANTHROPIC_MODEL=claude-3-sonnet-20240229
NEXUS_AI_ANTHROPIC_MAX_TOKENS=4096
NEXUS_AI_ANTHROPIC_TEMPERATURE=0.7

# --- OpenAI GPT ---
# Used directly by the AI tools: OPENAI_API_KEY
OPENAI_API_KEY=
NEXUS_AI_OPENAI_MODEL=gpt-4-turbo-preview
NEXUS_AI_OPENAI_MAX_TOKENS=4096
NEXUS_AI_OPENAI_TEMPERATURE=0.7

# --- Google Gemini ---
# Used directly by the AI tools: GEMINI_API_KEY
GEMINI_API_KEY=
NEXUS_AI_GEMINI_MODEL=gemini-pro
NEXUS_AI_GEMINI_MAX_TOKENS=1024
NEXUS_AI_GEMINI_TEMPERATURE=0.7

# --- Ollama (Local LLMs) ---
# Used directly by the AI tools: OLLAMA_HOST
OLLAMA_HOST=http://localhost:11434
NEXUS_AI_OLLAMA_DEFAULT_MODEL=llama2
NEXUS_AI_OLLAMA_NUM_PREDICT=128
NEXUS_AI_OLLAMA_TEMPERATURE=0.7

# --- Embeddings ---
NEXUS_AI_EMBEDDING_PROVIDER=openai
NEXUS_AI_EMBEDDING_MODEL=text-embedding-3-small
NEXUS_AI_VECTOR_STORE_PATH=./data/vectors

# ================================
# Utilities Configuration
# ================================
NEXUS_UTILITIES_ENABLED=true

# ================================
# Security Configuration
# ================================
NEXUS_SECURITY_ENABLE_RATE_LIMITING=true
NEXUS_SECURITY_RATE_LIMIT_REQUESTS=100
NEXUS_SECURITY_RATE_LIMIT_WINDOW=60000
NEXUS_SECURITY_ENABLE_AUDIT_LOG=true
NEXUS_SECURITY_AUDIT_LOG_PATH=logs/audit.log

# ================================
# Performance Configuration
# ================================
NEXUS_PERFORMANCE_CACHE_ENABLED=true
NEXUS_PERFORMANCE_CACHE_TTL=300000
NEXUS_PERFORMANCE_CACHE_MAX_SIZE=1000
NEXUS_PERFORMANCE_CONCURRENT_REQUESTS=10
NEXUS_PERFORMANCE_DB_POOL_SIZE=10
