{
  "name": "@nexus-mcp/server",
  "version": "1.0.0-alpha",
  "description": "Nexus MCP - A comprehensive Model Context Protocol toolkit for AI assistants",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nexus-mcp": "./dist/cli.js"
  },
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:mcp": "node dist/index.js",
    "cli": "ts-node src/cli.ts",
    "mcp": "node dist/cli.js start",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "jest --testPathPattern=tests/e2e",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run build",
    "prepare": "husky install"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "claude",
    "anthropic",
    "automation",
    "filesystem",
    "http",
    "git",
    "database",
    "tools"
  ],
  "author": "Nexus Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/Nexus-MCP.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/Nexus-MCP/issues"
  },
  "homepage": "https://github.com/your-org/Nexus-MCP#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.16.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "adm-zip": "^0.5.12",
    "axios": "^1.7.0",
    "commander": "^12.0.0",
    "cheerio": "^1.0.0-rc.12",
    "chokidar": "^3.6.0",
    "crypto-js": "^4.2.0",
    "csv-parse": "^5.5.5",
    "csv-stringify": "^6.4.5",
    "date-fns": "^3.3.0",
    "dotenv": "^16.4.0",
    "execa": "^8.0.1",
    "ioredis": "^5.3.2",
    "lru-cache": "^10.2.0",
    "mongodb": "^6.3.0",
    "mysql2": "^3.9.0",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "openai": "^4.28.0",
    "p-queue": "^8.0.1",
    "p-timeout": "^6.1.2",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.5",
    "pidusage": "^3.0.2",
    "sharp": "^0.33.2",
    "simple-git": "^3.36.0",
    "sqlite3": "^5.1.7",
    "systeminformation": "^5.22.0",
    "tar": "^6.2.0",
    "tedious": "^16.6.0",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xlsx": "^0.18.5",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.0",
    "@types/tar": "^6.1.11",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.5.0",
    "@typescript-eslint/parser": "^7.5.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.2",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "config"
  ],
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/cli.ts",
      "!src/index.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  }
}
